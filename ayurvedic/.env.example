# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Supabase — get these from: https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Sanity.io — get these from: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Optional read token for fetching draft content from server components
SANITY_API_READ_TOKEN=your-sanity-read-token
# Required by scripts/seed-treatments.ts (Editor or higher permissions)
SANITY_API_WRITE_TOKEN=your-sanity-write-token

# Billplz — get these from: https://www.billplz.com/enterprise/developer
BILLPLZ_API_KEY=your-billplz-api-key
BILLPLZ_COLLECTION_ID=your-billplz-collection-id
BILLPLZ_WEBHOOK_SECRET=your-billplz-x-signature-key

# Cal.com — get these from: https://app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=your-calcom-api-key
CALCOM_WEBHOOK_SECRET=your-calcom-webhook-secret

# Resend (Email) — get this from: https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
